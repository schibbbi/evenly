# Evenly — Environment Variables
# Copy this file to .env and fill in your values

# Claude API (used once at setup for task catalog generation)
CLAUDE_API_KEY=your_claude_api_key_here

# Google Calendar API (used for guest detection)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Database path (inside Docker volume)
DATABASE_URL=sqlite:////app/data/evenly.db

# App settings
APP_VERSION=0.1.0

# Google OAuth2 redirect URI (must match Google Cloud Console setting)
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/callback

# Frontend (R9)
VITE_API_URL=http://localhost:8000
# Frontend is served on port 3001 (change in docker-compose.yml if needed)
